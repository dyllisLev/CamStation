{
  "name": "camstation-viewer",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "main": "build/main.js",
  "scripts": {
    "test": "node --experimental-strip-types --test tests/*.test.ts",
    "build": "rm -rf build build-preload && tsc -p tsconfig.json && tsc -p tsconfig.preload.json && mv build-preload/preload.js build/preload.cjs && rm -rf build-preload",
    "package:win": "npm run build && node scripts/package-win.mjs",
    "generate:msi-files": "node ../scripts/generate-viewer-msi-files.mjs"
  },
  "devDependencies": {
    "@electron/packager": "20.0.2",
    "@types/node": "24.13.2",
    "electron": "43.1.1",
    "typescript": "6.0.2"
  }
}
